# ============================================================
# TWO DATABASES: production and development
#
# Production  = the live site on Vercel. Its values are set in the Vercel
#               dashboard (Project → Settings → Environment Variables).
#               Nothing on your laptop should point at it.
# Development = a separate, throwaway Supabase project used by `npm run dev`
#               and by any script you run locally. Breaking it costs nothing.
#
# This file is the template. Copy it to .env.local and fill in your
# DEVELOPMENT project's values. See docs/DATABASE_SETUP.md.
# ============================================================

# Which database do these values point at? Scripts that modify data refuse to
# run unless this says `development` (override with --allow-prod).
APP_DB_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Auth
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Email notifications (Resend) — optional.
# Without these the app still books appointments; it just skips the homeowner
# confirmation email and logs that it was skipped.
RESEND_API_KEY=re_your_api_key
# Must be a domain you've verified in Resend. Format: "Company <mail@yourdomain.com>"
RESEND_FROM_EMAIL=Your Company <appointments@yourdomain.com>
# Where homeowner replies go (optional)
RESEND_REPLY_TO=office@yourdomain.com

# IANA timezone used for the human-readable time in emails (default America/Phoenix).
# The attached calendar invite is always UTC, so each recipient's calendar shows
# it in their own zone regardless of this setting.
APP_TIME_ZONE=America/Phoenix
